# Set the API key for whichever provider you configure in configs/default.yml
# (only the matching one is required — not all three).

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (Codex / GPT)
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# VM benchmark (scripts/run_benchmark.sh). See docs/BENCHMARK_VM.md.
# ─────────────────────────────────────────────────────────────────────────────

# Fuzzer "deepseek" — DeepSeek R1 via its OpenAI-compatible API (real key).
# Uses the generic OpenAI-compatible client; NO local proxy server is involved.
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com      # default
# DEEPSEEK_MODEL=deepseek-reasoner                # default (R1)
# DEEPSEEK_MAX_TOKENS=0                            # 0 = no output cap (default)

# Fuzzer "chatgpt" (a.k.a. "openai") — direct OpenAI API (teacher's key).
# Reuses OPENAI_API_KEY above. Set OPENAI_MODEL to the exact id your key has.
# OPENAI_MODEL=o4-mini                            # default (reasoning model)
# OPENAI_MAX_TOKENS=0                              # 0 = no output cap (default);
#                                                 # set a number to cap output length.
# Note: token consumption is always recorded from each API response, with or
# without a cap. The cap only bounds per-call output length.

# Fuzzer "baseline" — plain AFL++, no keys needed.
