FROM aflplusplus/aflplusplus:latest

RUN apt-get update && apt-get install -y \
    autoconf \
    automake \
    libtool \
    pkg-config \
    zlib1g-dev \
    python3-pip \
    patch \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

RUN git clone https://github.com/glennrp/libpng.git /targets/libpng && \
    cd /targets/libpng && git checkout a37d4836519517bdce6cb9d956092321eca3e73b

RUN mkdir -p /targets/magma/libpng
COPY magma/targets/libpng/patches/ /targets/magma/libpng/patches/
RUN find /targets/magma/libpng/patches/setup \
         /targets/magma/libpng/patches/bugs \
         -name "*.patch" 2>/dev/null | sort | \
    while read patch; do \
        name=$(basename "$patch" .patch); \
        echo "Applying $name"; \
        sed "s/%MAGMA_BUG%/$name/g" "$patch" | patch -p1 -d /targets/libpng; \
    done

COPY targets/magma/libpng/Makefile /targets/magma/libpng/Makefile
COPY targets/magma/main_stub.cpp /targets/magma/libpng/main_stub.cpp

# Magma canary instrumentation (reach/trigger tracking for TTR/TTE, see
# magma/magma/src/canary.{c,h}). Built once here and linked into the AFL
# binary; harmless if unused by builds that don't pass -DMAGMA_ENABLE_CANARIES.
COPY magma/magma/src/ /magma_src/
RUN cc -fPIC -I/magma_src -DMAGMA_STORAGE='"/tmp/magma_canary_default.raw"' \
        -c /magma_src/canary.c -o /tmp/canary.o && \
    cc -fPIC -I/magma_src -DMAGMA_STORAGE='"/tmp/magma_canary_default.raw"' \
        -c /magma_src/storage.c -o /tmp/storage.o && \
    ld -r /tmp/canary.o /tmp/storage.o -o /targets/magma/libpng/magma.o && \
    rm /tmp/canary.o /tmp/storage.o

RUN mkdir -p /workspace/{corpus,output,mutators,distance_cache,coverage,logs,memory,instrumented,seed_code} \
    && mkdir -p /opt/mahybridfuzz/src

COPY src/ /opt/mahybridfuzz/src/
COPY configs/ /opt/mahybridfuzz/configs/

WORKDIR /opt/mahybridfuzz
ENV PYTHONPATH=/opt/mahybridfuzz/src

CMD ["python3", "src/orchestrator.py", "-c", "configs/magma/libpng.yml"]
