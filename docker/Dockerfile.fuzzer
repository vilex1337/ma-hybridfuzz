FROM aflplusplus/aflplusplus:latest

# Install Python dependencies
RUN apt-get update && apt-get install -y \
    python3-pip \
    python3-venv \
    clang \
    llvm \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Install Python packages
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Setup working directories
RUN mkdir -p /workspace/{corpus,crashes,mutators,distance_cache,coverage,logs} \
    && mkdir -p /opt/mahybridfuzz/src

COPY src/ /opt/mahybridfuzz/src/
COPY configs/ /opt/mahybridfuzz/configs/

WORKDIR /opt/mahybridfuzz
ENV PYTHONPATH=/opt/mahybridfuzz/src

# No ENTRYPOINT — the command is supplied by docker-compose.yml or via
# `docker compose run fuzzer <cmd>`.  Keeping a default CMD so plain
# `docker run` still boots the orchestrator.
CMD ["python3", "src/orchestrator.py", "-c", "configs/default.yml"]
